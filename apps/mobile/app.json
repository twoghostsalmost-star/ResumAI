{
  "expo": {
    "name": "ResumeForge",
    "slug": "resumeforge",
    "scheme": "resumeforge",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": ["ios"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.resumeforge.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ResumeForge uses the microphone for voice-guided resume building."
      }
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-audio"],
    "experiments": { "typedRoutes": true }
  }
}
