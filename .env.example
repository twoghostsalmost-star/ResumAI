# ── Backend (apps/api) ─────────────────────────────────────────────
DATABASE_URL="postgresql://resumeforge:resumeforge@localhost:5432/resumeforge?schema=public"
REDIS_URL="redis://localhost:6379"

# Object storage (S3-compatible)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="resumeforge"
S3_KEY="minioadmin"
S3_SECRET="minioadmin"

# AI / speech providers (server-side only — never shipped to the app)
ANTHROPIC_API_KEY=""
LLM_MODEL="claude-sonnet-4-6"

STT_PROVIDER="deepgram"          # deepgram | whisper
STT_API_KEY=""
TTS_PROVIDER="openai"            # elevenlabs | openai
TTS_API_KEY=""
TTS_VOICE_ID=""                  # provider voice id (optional)

# LinkedIn OAuth (OpenID Connect) — imports profile data into a resume
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:3000/linkedin/callback"

# Descope — auth (Google / Apple / passwordless are configured in the Descope
# console, not here). Project ID is public; the management key is optional and
# only used to read a user's email when it isn't in the session token claims.
DESCOPE_PROJECT_ID=""
DESCOPE_MANAGEMENT_KEY=""        # optional

# Security
PII_ENCRYPTION_KEY=""            # 32-byte base64 key
JWT_SIGNING_SECRET="dev-secret-change-me"
DEMO_USER_ID="demo-user"         # anonymous fallback identity for unauthenticated calls

PORT=3000
PUBLIC_BASE_URL="http://localhost:3000"   # used to build share links

# ── Web (apps/web) — public values only ────────────────────────────
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_DESCOPE_PROJECT_ID=""   # same Descope project id (public)

# ── Mobile (apps/mobile) — public values only ──────────────────────
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000"
