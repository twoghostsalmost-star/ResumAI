# Values for scripts/vercel-setup.sh — copy to .env.vercel.local (gitignored) and fill in.
# These are read by the script and pushed to Vercel as env vars; never commit real values.

# --- API project (resumeforge-api) ---
# Neon DIRECT/unpooled connection string (host WITHOUT -pooler), rotated password:
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
# Leave blank to auto-generate a strong one:
JWT_SIGNING_SECRET=""
# Your Descope project id (also used for the web client). Public value.
DESCOPE_PROJECT_ID=""
# Optional: only if the Descope session JWT doesn't include the user's email.
DESCOPE_MANAGEMENT_KEY=""
# Set after the first API deploy to the API's own URL (used for share links):
PUBLIC_BASE_URL=""

# --- Web project (resume-ai-web) ---
# The deployed API URL (set after the API is live), e.g. https://resumeforge-api.vercel.app
NEXT_PUBLIC_API_BASE_URL=""
